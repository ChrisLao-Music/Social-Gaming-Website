    const currentUser = users[0]; // NeonRider is the current user
    const userPosts = posts.filter(post => post.userId === currentUser.id);
    
    const container = document.getElementById('profilePostsGrid');
    
    if (userPosts.length === 0) {
        container.innerHTML = `
            <div class="glass" style="padding: 3rem; text-align: center; border-radius: 16px; grid-column: 1/-1;">
                <p style="color: var(--text-secondary);">No posts yet. Start sharing your gaming moments!</p>
            </div>
        `;
        return;
    }
    
    container.innerHTML = userPosts.map(post => `
        <div class="grid-post" data-testid="grid-post-${post.id}">
            ${post.image ? `<img src="${post.image}" alt="Post">` : `
                <div style="width: 100%; height: 100%; background: var(--glass-surface); display: flex; align-items: center; justify-content: center; color: var(--text-muted);">
                    <i class="ph ph-chat-circle" style="font-size: 3rem;"></i>
                </div>
            `}
            <div class="grid-post-overlay">
                <div class="overlay-stat">
                    <i class="ph-fill ph-heart"></i>
                    <span>${post.likes}</span>
                </div>
                <div class="overlay-stat">
                    <i class="ph-fill ph-chat-circle"></i>
                    <span>${post.comments.length}</span>
                </div>
            </div>
        </div>
    `).join('');
}

